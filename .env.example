# Copy to .env and adjust for your environment. Loaded via python-dotenv
# locally, or set directly as environment variables in Docker/hosting.

# Local docker-compose default — matches the postgres service below
DATABASE_URL=postgresql://neuralnav:neuralnav@localhost:5432/neuralnav

# Frontend -> backend URL (Streamlit reads this)
BACKEND_URL=http://localhost:8000

# Backend pulls trained models/kb.json from this HF Hub repo when not
# present locally (see notebooks/01 and 02, and ml/hf_hub.py). Needs read
# access if the repo is private.
HF_REPO_ID=BertinAm/neuralnav-intent-models
HF_TOKEN=
